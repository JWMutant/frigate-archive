############################################################
# Frigate Archive Git Ignore Rules
############################################################


############################################################
# Local Configuration
############################################################

# Each installation has its own paths and settings.
config.conf


############################################################
# Runtime Logs
############################################################

logs/*
!logs/.gitkeep


############################################################
# Runtime Backups
############################################################

backups/*
!backups/.gitkeep

*.backup.*


############################################################
# Temporary and Lock Files
############################################################

*.tmp
*.lock
*.pid
*.pyc
__pycache__/
.pytest_cache/


############################################################
# Shell and Editor Files
############################################################

*~
*.swp
*.swo
*.bak


############################################################
# Operating System Files
############################################################

.DS_Store
Thumbs.db



restore.sh.monolithic-backup
